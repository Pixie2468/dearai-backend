# App
APP_NAME="Dear AI"
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dearai

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM -- Vertex AI / Gemini
LLM_PROVIDER=vertex
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
LLM_MODEL=gemini-2.0-flash

# Sarvam AI (STT + TTS)
STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=en-IN

# Hume.ai (Emotion Detection -- optional fallback for STT/TTS)
HUME_API_KEY=your-hume-api-key
HUME_SECRET_KEY=your-hume-secret-key
HUME_TTS_VOICE=Kora

# FalkorDB (Graph RAG)
FALKOR_HOST=localhost
FALKOR_PORT=6379
FALKOR_GRAPH=dear_ai

# Guardrails
GUARDRAILS_ENABLED=true

# Redis Cache (used for RAG response caching)
REDIS_URL=redis://localhost:6380
RAG_CACHE_TTL_SECONDS=3600

# Summary generation
SUMMARY_INTERVAL=10
